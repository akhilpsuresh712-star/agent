# Copy to .env and fill in to use the LLM planner. The default planner is rule-based
# and needs none of this — demo and tests never depend on a live API.
PROCUREMENT_PLANNER=rule          # rule (default) | llm
GROQ_API_KEY=
PROCUREMENT_LLM_MODEL=openai/gpt-oss-20b   # small+fast; heavier: openai/gpt-oss-120b
PROCUREMENT_FIXTURES_DIR=fixtures
PROCUREMENT_LOG_LEVEL=INFO   # DEBUG to also log the raw planner intent
